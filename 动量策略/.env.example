# ===================================
# 动量策略 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===================================

# ---- 飞书通知配置 ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_WEBHOOK_URL=
FEISHU_TOKEN_EXPIRE_MINUTES=110

# ---- 数据库配置 ----
DATABASE_URL=sqlite:///./data/momentum_strategy.db

# ---- 日志配置 ----
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ---- 策略参数 ----
MOMENTUM_PERIOD=20
TOP_N=5
USE_EWMA=false
EWMA_ALPHA=0.1

# ---- 数据质量阈值 ----
PRICE_CHANGE_THRESHOLD=30
MIN_VOLUME_20D=1000000
MIN_VOLUME_AMOUNT=5000000

# ---- 调度配置 ----
PIPELINE_TIME=16:00
TOKEN_REFRESH_INTERVAL=7200

# ---- 推送配置 ----
PUSH_MODE=card
PUSH_FREQUENCY=daily

# ---- 数据源配置 ----
REQUEST_INTERVAL=1
MAX_RETRY=3
RETRY_DELAY=10
