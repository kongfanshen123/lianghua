FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_CHAT_ID=your_chat_id
FEISHU_TOKEN_EXPIRE_MINUTES=110

DATABASE_URL=sqlite:///./data/momentum_strategy.db

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

MOMENTUM_PERIOD=20
TOP_N=5
USE_EWMA=false
EWMA_ALPHA=0.1

PRICE_CHANGE_THRESHOLD=30
MIN_VOLUME_20D=1000000
MIN_VOLUME_AMOUNT=5000000

PIPELINE_TIME=16:00
TOKEN_REFRESH_INTERVAL=7200

PUSH_MODE=card
PUSH_FREQUENCY=daily

REQUEST_INTERVAL=1
MAX_RETRY=3
RETRY_DELAY=10
